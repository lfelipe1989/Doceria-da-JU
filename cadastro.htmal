<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Cadastre seu estabelecimento</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --dark:#1A1A2E; --dark2:#16213E; --accent:#E94560; --teal:#5BC8C0;
    --text:#E0E0E0; --muted:#9090A0; --border:rgba(255,255,255,0.1); --radius:16px;
  }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { font-family:'DM Sans',sans-serif; background:var(--dark); color:var(--text); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1.5rem; }

  .container { width:100%; max-width:560px; }
  .header { text-align:center; margin-bottom:2rem; }
  .header h1 { font-family:'Playfair Display',serif; font-size:2rem; color:white; margin-bottom:0.5rem; }
  .header p { font-size:0.9rem; color:var(--muted); }

  .card { background:var(--dark2); border:1px solid var(--border); border-radius:20px; padding:2rem; }
  .step { display:none; }
  .step.active { display:block; }
  .step-title { font-family:'Playfair Display',serif; font-size:1.2rem; color:white; margin-bottom:0.5rem; }
  .step-sub { font-size:0.82rem; color:var(--muted); margin-bottom:1.5rem; }

  .form-group { margin-bottom:1rem; }
  .form-label { font-size:0.78rem; color:var(--muted); display:block; margin-bottom:0.4rem; }
  .form-input { width:100%; padding:0.8rem 1rem; border:1px solid var(--border); border-radius:10px; font-family:'DM Sans',sans-serif; font-size:0.9rem; background:rgba(255,255,255,0.05); color:var(--text); outline:none; transition:border-color 0.2s; }
  .form-input:focus { border-color:var(--teal); }
  .form-hint { font-size:0.72rem; color:var(--muted); margin-top:4px; }
  .form-error { font-size:0.72rem; color:var(--accent); margin-top:4px; display:none; }
  .form-error.show { display:block; }

  .btn-next { width:100%; padding:0.9rem; background:var(--teal); color:var(--dark); border:none; border-radius:12px; font-family:'DM Sans',sans-serif; font-size:1rem; font-weight:500; cursor:pointer; margin-top:0.5rem; transition:opacity 0.2s; }
  .btn-next:hover { opacity:0.9; }
  .btn-back { background:none; border:none; color:var(--muted); font-size:0.85rem; cursor:pointer; font-family:'DM Sans',sans-serif; margin-top:0.75rem; display:block; text-align:center; width:100%; }

  .progress { display:flex; gap:6px; margin-bottom:1.5rem; }
  .progress-dot { flex:1; height:4px; border-radius:2px; background:var(--border); transition:background 0.3s; }
  .progress-dot.done { background:var(--teal); }
  .progress-dot.active { background:var(--accent); }

  .sucesso { text-align:center; padding:1rem; }
  .sucesso-icon { font-size:3rem; margin-bottom:1rem; }
  .sucesso h2 { font-family:'Playfair Display',serif; font-size:1.4rem; color:white; margin-bottom:0.5rem; }
  .sucesso p { font-size:0.85rem; color:var(--muted); margin-bottom:0.5rem; line-height:1.6; }
  .link-acesso { background:rgba(91,200,192,0.1); border:1px solid var(--teal); border-radius:10px; padding:0.75rem 1rem; font-size:0.85rem; color:var(--teal); margin:1rem 0; word-break:break-all; }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>🏪 Comece agora</h1>
    <p>Configure seu sistema de pedidos em menos de 2 minutos</p>
  </div>

  <div class="card">
    <div class="progress">
      <div class="progress-dot active" id="dot-1"></div>
      <div class="progress-dot" id="dot-2"></div>
      <div class="progress-dot" id="dot-3"></div>
    </div>

    <!-- STEP 1: Estabelecimento -->
    <div class="step active" id="step-1">
      <div class="step-title">Seu estabelecimento</div>
      <div class="step-sub">Como seu negócio se chama?</div>
      <div class="form-group">
        <label class="form-label">Nome do estabelecimento</label>
        <input class="form-input" type="text" id="s1-nome" placeholder="Ex: Doceria da Maria"/>
        <div class="form-error" id="err-nome">Por favor informe o nome.</div>
      </div>
      <div class="form-group">
        <label class="form-label">Endereço do seu sistema (slug)</label>
        <input class="form-input" type="text" id="s1-slug" placeholder="Ex: doceria-da-maria" oninput="this.value=this.value.toLowerCase().replace(/[^a-z0-9-]/g,'-')"/>
        <div class="form-hint">Será o link do seu painel: seuapp.com/<span id="slug-preview">...</span></div>
        <div class="form-error" id="err-slug">Slug já em uso. Escolha outro.</div>
      </div>
      <button class="btn-next" onclick="irStep2()">Continuar →</button>
    </div>

    <!-- STEP 2: Acesso -->
    <div class="step" id="step-2">
      <div class="step-title">Seu acesso</div>
      <div class="step-sub">Crie o login do painel administrativo</div>
      <div class="form-group">
        <label class="form-label">Seu nome</label>
        <input class="form-input" type="text" id="s2-nome" placeholder="Ex: Maria Silva"/>
      </div>
      <div class="form-group">
        <label class="form-label">E-mail</label>
        <input class="form-input" type="email" id="s2-email" placeholder="seu@email.com"/>
      </div>
      <div class="form-group">
        <label class="form-label">Senha</label>
        <input class="form-input" type="password" id="s2-senha" placeholder="Mínimo 6 caracteres"/>
      </div>
      <button class="btn-next" onclick="irStep3()">Continuar →</button>
      <button class="btn-back" onclick="irStep(1)">← Voltar</button>
    </div>

    <!-- STEP 3: Confirmação -->
    <div class="step" id="step-3">
      <div class="step-title">Quase lá! 🎉</div>
      <div class="step-sub">Confirme os dados antes de criar sua conta</div>
      <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:1rem;margin-bottom:1rem;font-size:0.85rem;line-height:2;">
        <div>🏪 <strong id="conf-nome"></strong></div>
        <div>🔗 Slug: <span id="conf-slug" style="color:var(--teal);"></span></div>
        <div>👤 <span id="conf-user"></span></div>
        <div>📧 <span id="conf-email"></span></div>
      </div>
      <button class="btn-next" id="btn-criar" onclick="criarConta()">✓ Criar minha conta</button>
      <button class="btn-back" onclick="irStep(2)">← Voltar</button>
    </div>

    <!-- SUCESSO -->
    <div class="step" id="step-sucesso">
      <div class="sucesso">
        <div class="sucesso-icon">🎉</div>
        <h2>Conta criada com sucesso!</h2>
        <p>Seu sistema está pronto. Acesse o painel admin com seu e-mail e senha.</p>
        <div class="link-acesso" id="link-acesso"></div>
        <p style="font-size:0.78rem;color:var(--muted);">Guarde esse link! Você também pode acessar direto pelo admin.html informando suas credenciais.</p>
        <button class="btn-next" onclick="window.location.href='admin.html'">Ir para o painel →</button>
      </div>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://jhnwtizmihecidadhubv.supabase.co';
const SUPABASE_KEY = 'sb_publishable_g1GinN-To8dOvXEzqnAy6A_33x-9yA9';

async function supaFetch(path, method='GET', body=null) {
  const opts = { method, headers: { 'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY,'Content-Type':'application/json','Prefer':method==='POST'?'return=representation':'' } };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(SUPABASE_URL+'/rest/v1/'+path, opts);
  if (!res.ok) throw new Error(await res.text());
  return method==='PATCH'? null : res.json();
}

document.getElementById('s1-nome').addEventListener('input', function() {
  const slug = this.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
  document.getElementById('s1-slug').value = slug;
  document.getElementById('slug-preview').textContent = slug || '...';
});
document.getElementById('s1-slug').addEventListener('input', function() {
  document.getElementById('slug-preview').textContent = this.value || '...';
});

async function irStep2() {
  const nome = document.getElementById('s1-nome').value.trim();
  const slug = document.getElementById('s1-slug').value.trim();
  if (!nome) { document.getElementById('err-nome').classList.add('show'); return; }
  document.getElementById('err-nome').classList.remove('show');
  if (!slug) { alert('Informe um slug!'); return; }
  // Verifica se slug já existe
  try {
    const existe = await supaFetch('estabelecimentos?slug=eq.'+slug);
    if (existe && existe.length > 0) { document.getElementById('err-slug').classList.add('show'); return; }
    document.getElementById('err-slug').classList.remove('show');
    irStep(2);
  } catch(e) { irStep(2); }
}

function irStep3() {
  const nome = document.getElementById('s2-nome').value.trim();
  const email = document.getElementById('s2-email').value.trim();
  const senha = document.getElementById('s2-senha').value;
  if (!nome||!email||!senha) { alert('Preencha todos os campos!'); return; }
  if (senha.length < 6) { alert('Senha precisa ter pelo menos 6 caracteres!'); return; }
  document.getElementById('conf-nome').textContent = document.getElementById('s1-nome').value.trim();
  document.getElementById('conf-slug').textContent = document.getElementById('s1-slug').value.trim();
  document.getElementById('conf-user').textContent = nome;
  document.getElementById('conf-email').textContent = email;
  irStep(3);
}

async function criarConta() {
  const btn = document.getElementById('btn-criar');
  btn.textContent = 'Criando...'; btn.disabled = true;
  try {
    const nome = document.getElementById('s1-nome').value.trim();
    const slug = document.getElementById('s1-slug').value.trim();
    const res = await supaFetch('estabelecimentos','POST',{ nome, slug, plano:'trial', mensalidade:0, vencimento_dia:5 });
    const estabId = res[0].id;
    await supaFetch('usuarios','POST',{ estabelecimento_id:estabId, nome:document.getElementById('s2-nome').value.trim(), email:document.getElementById('s2-email').value.trim(), senha_hash:document.getElementById('s2-senha').value, papel:'admin' });

    // Cria produtos padrão para o estabelecimento
    await supaFetch('produtos','POST',{ nome:'Produto 1', emoji:'🛍️', descricao:'Clique em Cardápio para personalizar', preco:10.00, ativo:true, estabelecimento_id:estabId });

    document.getElementById('link-acesso').textContent = window.location.origin+'/admin.html';
    irStep('sucesso');
  } catch(e) {
    btn.textContent = '✓ Criar minha conta'; btn.disabled = false;
    alert('Erro ao criar conta. Tente novamente.');
  }
}

function irStep(n) {
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById('step-'+n).classList.add('active');
  for(let i=1;i<=3;i++) {
    const dot = document.getElementById('dot-'+i);
    if (!dot) continue;
    dot.className = 'progress-dot' + (i<n?' done':i===n?' active':'');
  }
}
</script>
</body>
</html>
